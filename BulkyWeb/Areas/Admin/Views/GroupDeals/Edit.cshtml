@model BulkyBook.Models.GroupDeal

<div class="container mt-4">
    <h2>Create Group Deal</h2>

    <form method="post">
        <div class="mb-3">
            <label>Product</label>
            <select name="ProductId" class="form-control">
                @foreach (var p in ViewBag.Products)
                {
                    <option value="@p.Id">@p.Title</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label>Required Users</label>
            <input type="number" name="RequiredUsers" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Discount Price</label>
            <input type="number" name="DiscountPrice" class="form-control" step="0.01" />
        </div>

        <div class="mb-3">
            <label>Expiration Date</label>
            <input type="datetime-local" name="ExpirationDate" class="form-control" />
        </div>

        <button class="btn btn-primary">Create</button>
    </form>
</div>
