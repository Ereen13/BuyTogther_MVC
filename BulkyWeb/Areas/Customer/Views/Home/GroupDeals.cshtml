@model IEnumerable<BulkyBook.Models.GroupDeal>

<h2 class="mb-4">Current Group Deals</h2>
<div class="row">
    @foreach (var deal in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <img src="@(deal.Product.ProductImages.FirstOrDefault()?.ImageUrl ?? "https://placehold.co/500x600/png")"
                     class="card-img-top" />
                <div class="card-body">
                    <h5 class="card-title">@deal.Product.Title</h5>
                    <p>Discount: @deal.DiscountPrice.ToString("c")</p>
                    <p>Joined: @deal.JoinedUsersCount / @deal.RequiredUsers</p>
                    <a asp-action="DealDetails" asp-route-id="@deal.DealId" class="btn btn-primary w-100">Details</a>
                </div>
            </div>
        </div>
    }
</div>
